{
  "name": "mcp-telemetry",
  "private": true,
  "description": "Socket.IO-style telemetry for MCP servers — instrument any tool call, watch live progress from any MCP client.",
  "license": "MIT",
  "author": "Arnav Ranjan <arnavranjan005@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arnavranjan005/mcp-telemetry.git"
  },
  "homepage": "https://github.com/arnavranjan005/mcp-telemetry#readme",
  "bugs": {
    "url": "https://github.com/arnavranjan005/mcp-telemetry/issues"
